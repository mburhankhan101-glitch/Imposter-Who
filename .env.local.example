# For local dev, `partykit dev` runs on localhost:1999 by default and the
# client falls back to that automatically — you don't need this file for
# local development.
#
# Once you deploy the party server (npm run party:deploy), PartyKit will
# print a host like "imposter-who.yourusername.partykit.dev". Copy it here
# (and set the same var in your Vercel project) so the deployed client
# connects to the deployed room server instead of localhost.
NEXT_PUBLIC_PARTYKIT_HOST=imposter-who.yourusername.partykit.dev
