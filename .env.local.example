# For local dev, `npm run server:dev` runs the room server on localhost:1999
# and the client falls back to that automatically — you don't need this file
# for local development.
#
# Once you deploy the room server to Render.com (New -> Blueprint -> this repo,
# which reads render.yaml), you'll get a host like
# "imposter-who-server.onrender.com". Put just the HOST (no https://) here and
# set the same var in your Vercel project, so the deployed client connects to
# the deployed room server instead of localhost.
NEXT_PUBLIC_PARTYKIT_HOST=imposter-who-server.onrender.com
